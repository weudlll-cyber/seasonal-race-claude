{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "attribution": {
    "commit": "",
    "pr": ""
  },
  "permissions": {
    "defaultMode": "bypassPermissions",
    "allow": [
      "Bash(git *)",
      "Bash(npm *)",
      "Bash(node *)",
      "Bash(gh *)",
      "Bash(ls *)",
      "Bash(cat *)",
      "Bash(cd *)",
      "Bash(pwd)",
      "Bash(mkdir *)",
      "Bash(rm *)",
      "Bash(rmdir *)",
      "Bash(del *)",
      "Read",
      "Write",
      "Edit",
      "Bash(wc *)",
      "Bash(echo *)",
      "Bash(for *)",
      "Bash(find *)",
      "Bash(grep *)",
      "Bash(head *)",
      "Bash(tail *)",
      "Bash(sort *)",
      "Bash(netstat *)",
      "Bash(tasklist)",
      "Bash(taskkill *)"
    ],
    "deny": [
      "Bash(curl *)",
      "Bash(wget *)"
    ]
  }
}
